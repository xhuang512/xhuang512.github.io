---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Resume" sideBarActiveItemID="cv">
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Resume</div>
  </div>

  <div class="mb-6 text-justify opacity-80">
    Last updated: May 19, 2026
  </div>

  <div class="mb-6 flex flex-wrap gap-3">
    <a href="/resume.pdf" target="_blank" class="btn btn-primary">
      View Resume
    </a>

    <a href="/resume.pdf" download class="btn btn-outline">
      Download Resume
    </a>
  </div>

  <p class="opacity-80">
    For the best viewing experience, please open the resume in a new tab.
  </p>
</BaseLayout>